# Backend Environment Variables Template
# Copy to .env and fill in your values

# ==============================================
# MODE SELECTION
# ==============================================
# Set to 'true' for cloud deployment (Firestore + Auth)
# Set to 'false' for local development (SQLite, no auth)
USE_FIRESTORE=false

# ==============================================
# FIREBASE / GOOGLE CLOUD
# ==============================================
# Path to Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT=./firebase-key.json

# IMPORTANT: Firebase project id used for verifying Firebase ID tokens.
# Must match the frontend's REACT_APP_FIREBASE_PROJECT_ID.
FIREBASE_PROJECT_ID=your-firebase-project-id

# GCP Project settings
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# Path to GCP service account JSON. Use relative path (e.g. ./firebase-key.json).
# Never commit absolute paths or the key file itself.
# For Cloud Run, ADC is used automatically; this is for local/dev.
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json

# ==============================================
# CLOUD STORAGE
# ==============================================
# Bucket name for file storage
GCS_BUCKET=canvas-organizer-files

# ==============================================
# VERTEX AI (Gemini)
# ==============================================
VERTEX_AI_PROJECT=your-project-id
VERTEX_AI_LOCATION=us-central1
# Optional model override (default in code: gemini-2.5-flash-lite)
# MODEL_NAME=gemini-2.5-flash-lite

# Estimated pricing used for per-call cost logs (USD per 1M tokens).
# You can set global defaults:
# GEMINI_INPUT_COST_PER_1M_USD=0.10
# GEMINI_OUTPUT_COST_PER_1M_USD=0.40
# Or model-specific overrides (MODEL_NAME -> upper snake case):
# GEMINI_2_5_FLASH_LITE_INPUT_COST_PER_1M_USD=0.10
# GEMINI_2_5_FLASH_LITE_OUTPUT_COST_PER_1M_USD=0.40

# Optional OpenTelemetry log export settings for AI usage logs.
# If unset, the backend falls back to console OTEL exporter.
# OTEL_SERVICE_NAME=canvas-organizer-backend
# OTEL_SERVICE_VERSION=1.0.0
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector/v1/logs
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your-token

# ==============================================
# SERVER SETTINGS
# ==============================================
PORT=5000
FLASK_DEBUG=false

# ==============================================
# CANVAS API (optional, per-user in cloud mode)
# ==============================================
# Only needed for local development mode
# CANVAS_API_URL=https://your-school.instructure.com
# CANVAS_API_TOKEN=your-canvas-token

# Security: Restrict which Canvas hostnames are allowed as base URLs.
# Comma-separated wildcard patterns; default in code is *.instructure.com
# Add your custom Canvas domain here if needed.
# CANVAS_ALLOWED_HOST_PATTERNS=*.instructure.com,canvas.youruniversity.edu

# Timeout (seconds) for outbound Canvas requests.
# CANVAS_REQUEST_TIMEOUT_SECONDS=20

# Hourly sync limit per authenticated user.
# This is enforced on /api/sync_course_materials and defaults to 100.
# COURSE_SYNC_RATE_LIMIT_PER_HOUR=100
#
# SECURITY: RELAX_SYNC_RATE_LIMITS_FOR_TESTING must NEVER be set in production
# or any public deployment. It is for local development only.

# ==============================================
# CLOUD COST AUDIT (optional)
# ==============================================
# Disabled by default in production. Set ENABLE_CLOUD_COST_AUDIT_ENDPOINT=true
# and CLOUD_COST_ALLOWED_EMAILS to enable the /api/cloud/cost-audit endpoint.
# ENABLE_CLOUD_COST_AUDIT_ENDPOINT=false
# CLOUD_COST_ALLOWED_EMAILS=admin@example.com

# ==============================================
# ENCRYPTION
# ==============================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used to encrypt Canvas API tokens in the database.
# Required when USE_FIRESTORE=true. The backend now fails fast if this is missing.
# CANVAS_TOKEN_ENCRYPTION_KEY=your-fernet-key-here
