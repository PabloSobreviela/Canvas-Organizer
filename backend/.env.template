# Backend Environment Variables Template
# Copy to .env and fill in your values

# ==============================================
# SUPABASE
# ==============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=course-files

# ==============================================
# CANVAS OAUTH2
# ==============================================
# Developer key from Instructure / university admin (GT OIT)
CANVAS_OAUTH_CLIENT_ID=placeholder-until-GT-OIT-provides
CANVAS_OAUTH_CLIENT_SECRET=placeholder-until-GT-OIT-provides
CANVAS_INSTANCE_URL=https://gatech.instructure.com
CANVAS_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/canvas/callback

# Where to redirect after successful OAuth login
FRONTEND_URL=http://localhost:3000

# ==============================================
# SESSION
# ==============================================
# Secret key for signing JWT session tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=change-me-to-a-random-secret

# ==============================================
# LLM INFERENCE (Primary: OpenRouter, Fallback: DeepInfra)
# ==============================================
# Primary provider API key (OpenRouter). Required for AI features.
LLM_API_KEY=your-openrouter-api-key
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Primary model (Qwen 3.5 Flash, 1M context, $0.065/$0.26 per 1M tokens).
# MODEL_NAME=qwen/qwen3.5-flash-02-23

# Fallback provider API key (DeepInfra). Used when primary fails.
LLM_FALLBACK_API_KEY=your-deepinfra-api-key
# LLM_FALLBACK_BASE_URL=https://api.deepinfra.com/v1/openai

# Fallback model (Qwen 3 14B on DeepInfra).
# FALLBACK_MODEL=Qwen/Qwen3-14B

# Estimated pricing used for per-call cost logs (USD per 1M tokens).
# LLM_INPUT_COST_PER_1M_USD=0.065
# LLM_OUTPUT_COST_PER_1M_USD=0.26

# ==============================================
# SERVER SETTINGS
# ==============================================
PORT=5000
FLASK_DEBUG=false

# ==============================================
# CANVAS API SETTINGS
# ==============================================
# Security: Restrict which Canvas hostnames are allowed as base URLs.
# CANVAS_ALLOWED_HOST_PATTERNS=*.instructure.com

# Timeout (seconds) for outbound Canvas requests.
# CANVAS_REQUEST_TIMEOUT_SECONDS=20

# Hourly sync limit per authenticated user.
# COURSE_SYNC_RATE_LIMIT_PER_HOUR=100

# ==============================================
# ENCRYPTION
# ==============================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used to encrypt Canvas OAuth tokens in the database.
CANVAS_TOKEN_ENCRYPTION_KEY=your-fernet-key-here
