# =============================================================================
# SECRETS & CREDENTIALS - NEVER COMMIT
# =============================================================================
backend/firebase_key.json
backend/firebase-key.json
backend/.env
backend/.env.*
!backend/.env.template
backend/Amazon secret access key.txt
backend/*secret*key*
backend/*.pem
backend/*-key.json

frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production
frontend/.env.production.local
!frontend/.env.template

# Google Cloud OAuth tokens and credentials
.gcloud-config/
.gcloud-tmp/

# Local user data and cached course materials
backend/data/
data/

# SQLite / local DBs
*.db
*.sqlite
*.sqlite3

# =============================================================================
# DEPENDENCIES (reinstall with npm install / pip install)
# =============================================================================
node_modules/
frontend/node_modules/
backend/venv/
.venv/

# =============================================================================
# BUILD OUTPUT (regenerate with npm run build)
# =============================================================================
frontend/build/

# =============================================================================
# IDE & CACHE
# =============================================================================
.idea/
.firebase/
*.log
